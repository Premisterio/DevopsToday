          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_id\": 129884\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/places",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "places"]
            }
          }
        },
        {
          "name": "Add place — invalid artwork (422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 422', () => pm.response.to.have.status(422));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_id\": 999999999\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/places",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "places"]
            }
          }
        },
        {
          "name": "List places for project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/places",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "places"]
            }
          }
        },
        {
          "name": "Get single place",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Has external_id', () => pm.expect(body.external_id).to.be.a('number'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/places/{{placeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "places", "{{placeId}}"]
            }
          }
        },
        {
          "name": "Update place notes",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Notes updated', () => pm.expect(pm.response.json().notes).to.eql('Absolutely stunning painting.'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Absolutely stunning painting.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/places/{{placeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "places", "{{placeId}}"]
            }
          }
        },
        {
          "name": "Mark place as visited",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is visited', () => pm.expect(pm.response.json().is_visited).to.eql(true));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_visited\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/places/{{placeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "places", "{{placeId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Business Rules",
      "item": [
        {
          "name": "Delete project with visited places (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error message', () => pm.expect(pm.response.json().detail).to.include('visited'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}"]
            },
            "description": "Should fail because the project has a visited place from the previous test."
          }
        },
        {
          "name": "Auto-complete — verify project completed",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body.places && body.places.length > 0 && body.places.every(p => p.is_visited)) {",
                  "  pm.test('Project is completed', () => pm.expect(body.is_completed).to.eql(true));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}"]
            },
            "description": "If all places in this project are visited, is_completed should be true."
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Root",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
